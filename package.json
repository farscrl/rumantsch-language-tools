{
  "name": "@farscrl/rumantsch-language-tools",
  "version": "1.0.5",
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184",
  "description": "A collection of tools is designed to aid in working with the Rumantsch (Romansh) language",
  "author": "far ScRL",
  "license": "MIT",
  "homepage": "https://github.com/farscrl/rumantsch-language-tools/tree/main",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js"
    }
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jestconfig.json",
    "build": "tsup",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
    "lint": "eslint src",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm test && pnpm run lint",
    "preversion": "pnpm run lint",
    "version": "pnpm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "rumantsch",
    "romontsch",
    "rumauntsch",
    "romansh",
    "tokenizer",
    "spellchecker"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "@farscrl/hunspell-wasm": "^1.0.0"
  },
  "files": [
    "lib/**/*"
  ]
}
